# Required: PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/shengfeng_erp

# Server port (default: 3000)
PORT=3000

# Node environment
NODE_ENV=production

# JWT secret — change this to a long random string in production
JWT_SECRET=change-me-in-production

# AI voice — OpenAI Whisper speech-to-text (required for server-side transcription)
OPENAI_API_KEY=
# Optional override (defaults to openai_whisper when OPENAI_API_KEY is set)
# VOICE_SPEECH_PROVIDER=openai_whisper
