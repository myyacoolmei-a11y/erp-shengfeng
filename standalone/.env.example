# Required: PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/shengfeng_erp

# Server port (default: 3000)
PORT=3000

# Node environment
NODE_ENV=production

# JWT secret — change this to a long random string in production
JWT_SECRET=change-me-in-production

# AI voice — OpenAI Whisper speech-to-text (required for server-side transcription)
OPENAI_API_KEY=
# Optional override (defaults to openai_whisper when OPENAI_API_KEY is set)
# VOICE_SPEECH_PROVIDER=openai_whisper

# Public ERP URL for LINE reminder links
APP_BASE_URL=https://bountiful-vitality-production-76ab.up.railway.app

# LINE Messaging API (AI 小秘書)
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# Optional external cron secret for POST /api/jobs/receivable-collection-reminder
CRON_SECRET=

# Web Push (派工進度推播) — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@yourdomain.com

# Public ERP URL (Web Push / LINE deep links)
APP_BASE_URL=https://your-app.up.railway.app
