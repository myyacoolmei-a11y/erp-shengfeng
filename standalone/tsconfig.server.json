{
  "compilerOptions": {
    "target": "es2022",
    "lib": ["es2022"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noEmit": true,
    "types": ["node"],
    "paths": {
      "@workspace/db": ["./shared/db/index.ts"],
      "@workspace/api-zod": ["./shared/schemas/index.ts"]
    }
  },
  "include": ["server/**/*", "shared/db/**/*", "shared/schemas/**/*"]
}
